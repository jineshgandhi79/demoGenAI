JWT_SECRET=super_long_random_secret_here
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ai_support
MONGODB_DB_NAME=ai_support
GEMINI_API_KEY=your_gemini_api_key
GEMINI_CHAT_MODEL=gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION_NAME=knowledge_base_vectors
QDRANT_VECTOR_SIZE=768
RAG_TOP_K=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_SCORE_THRESHOLD=0.7
CONFIDENCE_THRESHOLD=0.6
MAX_FILE_SIZE_MB=20
UPLOAD_DIR=uploads
ALLOWED_FILE_TYPES=pdf,md
URL_FETCH_TIMEOUT_MS=10000
MAX_URL_CONTENT_LENGTH=500000
ESCALATION_PREFIX=TKT
ANALYTICS_ENABLED=true
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info
PORT=5000
